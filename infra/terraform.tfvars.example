# Copy this to terraform.tfvars (gitignored) and fill in real values
# Never commit terraform.tfvars — it contains secrets

aws_region     = "us-east-1"
aws_account_id = "973028704465"
environment    = "production"

# PostgreSQL connection string
db_url = "postgresql://user:password@host:5432/arnievulnai"

# VirusTotal API key (stored in Secrets Manager via Terraform)
